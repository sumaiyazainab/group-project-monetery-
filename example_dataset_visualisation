def find_orfs_circular(seq: str,
                      min_len_bp: int = 2000,
                      max_len_bp: int = 4500) -> List[Dict]:
    """
    Find ORFs in a circular DNA sequence by scanning a doubled sequence,
    then mapping coordinates back to original.
    """
    n = len(seq)
    seq2 = seq + seq
    results = []

    def scan_strand(s: str, strand: str):
        for frame in range(3):
            i = frame
            while i < 2*n - 2:
                codon = s[i:i+3]
                if codon == "ATG":
                    # extend until stop or length exceeds max
                    j = i
                    while j < 2*n - 2:
                        cod = s[j:j+3]
                        if cod in STOP_CODONS:
                            orf_len = (j + 3) - i
                            if min_len_bp <= orf_len <= max_len_bp:
                                start = i
                                end = j + 3  # exclusive
                                # only accept ORFs that start in first n region
                                if start < n:
                                    results.append({
                                        "strand": strand,
                                        "frame": frame,
                                        "start": start,  # in doubled coords
                                        "end": end,      # in doubled coords
                                        "len_bp": orf_len
                                    })
                            break
                        if (j - i) > max_len_bp:
                            break
                        j += 3
                    i = j + 3
                else:
                    i += 3

    scan_strand(seq2, "+")
    scan_strand(revcomp(seq2), "-")
    return results

def pick_best_orf(seq: str) -> Dict:
    orfs = find_orfs_circular(seq)
    if not orfs:
        raise ValueError("No ORFs found in expected size range. Try adjusting min_len_bp/max_len_bp.")
    # choose the longest ORF (typical for polymerase gene)
    best = sorted(orfs, key=lambda x: x["len_bp"], reverse=True)[0]
    return best

