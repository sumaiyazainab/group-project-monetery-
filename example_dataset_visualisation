def find_rotation_offset(wt_seq: str, var_seq: str, k: int = 60, max_tries: int = 200) -> Optional[int]:
    """
    Find offset such that rotating var_seq by that offset matches wt_seq orientation.
    Returns offset where var_rot = var_seq[offset:] + var_seq[:offset].
    """
    n = len(wt_seq)
    if len(var_seq) != n:
        # If lengths differ, rotation is harder; you can still attempt but identity will drop.
        # For now, require same length (typical here).
        return None

    # Try multiple anchors from WT to avoid anchor spanning a mutation
    step = max(1, (n - k) // max_tries)
    for start in range(0, min(n - k, step * max_tries), step):
        anchor = wt_seq[start:start+k]
        idx = var_seq.find(anchor)
        if idx != -1:
            # anchor at wt start corresponds to var idx; want var_rot[ start:start+k ] == anchor
            # If we rotate by (idx - start), then var_rot[start] = var[idx]
            offset = (idx - start) % n
            return offset
    return None

def rotate(seq: str, offset: int) -> str:
    n = len(seq)
    offset = offset % n
    return seq[offset:] + seq[:offset]

def best_oriented_variant(wt_seq: str, var_seq: str, k: int = 60) -> Tuple[str, str]:
    """
    Return (var_rotated, orientation) where orientation is '+' or '-'.
    Chooses between forward and reverse-complement based on which can be rotated to match WT.
    """
    # Try forward
    off_f = find_rotation_offset(wt_seq, var_seq, k=k)
    if off_f is not None:
        return rotate(var_seq, off_f), "+"

    # Try reverse complement
    var_rc = revcomp(var_seq)
    off_r = find_rotation_offset(wt_seq, var_rc, k=k)
    if off_r is not None:
        return rotate(var_rc, off_r), "-"

    # If no anchor found, return as-is (still usable for crude counts, but less reliable)
    return var_seq, "?"

def count_mutations_in_cds(wt_plasmid_seq: str,
                           var_plasmid_seq: str,
                           wt_orf_info: Dict,
                           wt_cds_seq: str,
                           wt_aa_seq: str) -> Tuple[int, int]:
    """
    Returns (nt_mutations_in_cds, aa_mutations).
    """
    var_oriented, orient = best_oriented_variant(wt_plasmid_seq, var_plasmid_seq)

    # Extract CDS from oriented variant using the same coordinates and strand logic as WT ORF.
    if wt_orf_info["strand"] == "+":
        var_cds = extract_circular_region(var_oriented, wt_orf_info["start"], wt_orf_info["end"])
    else:
        # If WT gene is on '-', we should extract from reverse-complement reference.
        # Here we replicate the WT extraction logic:
        rc_var = revcomp(var_oriented)
        cds_rc = extract_circular_region(rc_var, wt_orf_info["start"], wt_orf_info["end"])
        var_cds = revcomp(cds_rc)

    # NT mutation count (simple Hamming distance)
    nt_mut = sum(1 for a, b in zip(wt_cds_seq, var_cds) if a != b)

    # AA mutation count (translate both, compare positions)
    var_aa = translate_dna(var_cds)
    L = min(len(wt_aa_seq), len(var_aa))
    aa_mut = sum(1 for i in range(L) if wt_aa_seq[i] != var_aa[i]) + abs(len(wt_aa_seq) - len(var_aa))

    return nt_mut, aa_mut



def add_mutation_counts(df: pd.DataFrame,
                        wt_plasmid_seq: str,
                        wt_orf_info: Dict) -> pd.DataFrame:
    wt_cds_seq, wt_aa_seq = get_wt_cds_and_protein(wt_plasmid_seq, wt_orf_info)

    nt_list = []
    aa_list = []

    for seq in df["Assembled_DNA_Sequence"].tolist():
        nt_mut, aa_mut = count_mutations_in_cds(
            wt_plasmid_seq=wt_plasmid_seq,
            var_plasmid_seq=seq,
            wt_orf_info=wt_orf_info,
            wt_cds_seq=wt_cds_seq,
            wt_aa_seq=wt_aa_seq
        )
        nt_list.append(nt_mut)
        aa_list.append(aa_mut)

    out = df.copy()
    out["NT_Mutations_vs_WT_in_Gene"] = nt_list
    out["AA_Mutations_vs_WT"] = aa_list
    return out

