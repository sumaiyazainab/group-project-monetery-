def read_fasta_single(path: str) -> str:
    seq_lines = []
    with open(path, "r") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            if line.startswith(">"):
                continue
            seq_lines.append(line)
    seq = "".join(seq_lines).replace(" ", "").replace("\t", "").upper()
    if not seq:
        raise ValueError("FASTA appears empty.")
    return seq

