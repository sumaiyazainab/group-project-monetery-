def plot_activity_distribution(df: pd.DataFrame):
    # only non-control or include all? Usually show all variants (including controls can compress scale)
    plot_df = df[df["Control"] == False].copy()

    gens = sorted(plot_df["Directed_Evolution_Generation"].dropna().unique().tolist())
    data = [plot_df.loc[plot_df["Directed_Evolution_Generation"] == g, "Activity_Score"].dropna().values for g in gens]

    plt.figure(figsize=(10, 5))
    plt.violinplot(data, showmeans=True, showmedians=True)
    plt.xticks(np.arange(1, len(gens) + 1), [str(g) for g in gens])
    plt.xlabel("Generation")
    plt.ylabel("WT-normalised Activity Score")
    plt.title("Activity Score Distribution by Generation")
    plt.grid(True, alpha=0.3)
    plt.show()

