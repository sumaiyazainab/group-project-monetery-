df_land[["Plasmid_Variant_Index", "Directed_Evolution_Generation", "Activity_Score"]].head()

# k-mer vectorisation for protein sequences
k = 3
vectorizer = CountVectorizer(analyzer="char", ngram_range=(k, k))
X = vectorizer.fit_transform(df_land["Protein_Seq"])

# Dimensionality reduction to 2D (PCA is fast + deterministic)
pca = PCA(n_components=2, random_state=42)
coords_2d = pca.fit_transform(X.toarray())

df_land["Dim1"] = coords_2d[:, 0]
df_land["Dim2"] = coords_2d[:, 1]

# Training data
xy = df_land[["Dim1", "Dim2"]].values
z = df_land["Activity_Score"].values

# Grid over the 2D space
grid_size = 70  # increase to 100 for smoother surface (slower)
x_lin = np.linspace(df_land["Dim1"].min(), df_land["Dim1"].max(), grid_size)
y_lin = np.linspace(df_land["Dim2"].min(), df_land["Dim2"].max(), grid_size)
xx, yy = np.meshgrid(x_lin, y_lin)
grid_xy = np.c_[xx.ravel(), yy.ravel()]

# KNN regression to predict activity over the grid
knn = KNeighborsRegressor(n_neighbors=20, weights="distance")
knn.fit(xy, z)
zz = knn.predict(grid_xy).reshape(grid_size, grid_size)

fig = go.Figure()

# Surface (topography)
fig.add_trace(go.Surface(
    x=xx, y=yy, z=zz,
    surfacecolor=zz,   # color by activity
    opacity=0.95,
    colorbar=dict(title="Activity Score")
))

# Points (actual variants)
fig.add_trace(go.Scatter3d(
    x=df_land["Dim1"], y=df_land["Dim2"], z=df_land["Activity_Score"],
