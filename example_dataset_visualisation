ef variant_protein_sequence(wt_plasmid_seq: str, wt_orf_info: dict, var_plasmid_seq: str) -> str:
    var_oriented, _ = best_oriented_variant(wt_plasmid_seq, var_plasmid_seq, k=60)

    if wt_orf_info["strand"] == "+":
        var_cds = extract_circular_region(var_oriented, wt_orf_info["start"], wt_orf_info["end"])
    else:
        rc_var = revcomp(var_oriented)
        cds_rc = extract_circular_region(rc_var, wt_orf_info["start"], wt_orf_info["end"])
        var_cds = revcomp(cds_rc)

    return translate_dna(var_cds)

