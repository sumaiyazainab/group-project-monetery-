DNA_COMP = str.maketrans("ACGTacgt", "TGCAtgca")

def revcomp(seq: str) -> str:
    return seq.translate(DNA_COMP)[::-1]

STOP_CODONS = {"TAA", "TAG", "TGA"}

CODON_TABLE = {
    # Standard genetic code (bacterial also uses standard for translation)
    "TTT":"F","TTC":"F","TTA":"L","TTG":"L",
    "TCT":"S","TCC":"S","TCA":"S","TCG":"S",
    "TAT":"Y","TAC":"Y","TAA":"*","TAG":"*",
    "TGT":"C","TGC":"C","TGA":"*","TGG":"W",
    "CTT":"L","CTC":"L","CTA":"L","CTG":"L",
    "CCT":"P","CCC":"P","CCA":"P","CCG":"P",
    "CAT":"H","CAC":"H","CAA":"Q","CAG":"Q",
    "CGT":"R","CGC":"R","CGA":"R","CGG":"R",
    "ATT":"I","ATC":"I","ATA":"I","ATG":"M",
    "ACT":"T","ACC":"T","ACA":"T","ACG":"T",
    "AAT":"N","AAC":"N","AAA":"K","AAG":"K",
    "AGT":"S","AGC":"S","AGA":"R","AGG":"R",
    "GTT":"V","GTC":"V","GTA":"V","GTG":"V",
    "GCT":"A","GCC":"A","GCA":"A","GCG":"A",
    "GAT":"D","GAC":"D","GAA":"E","GAG":"E",
    "GGT":"G","GGC":"G","GGA":"G","GGG":"G",
}

def translate_dna(seq: str) -> str:
    """Translate a coding DNA sequence (assumes frame is correct). Stops at first stop codon."""
    aa = []
    for i in range(0, len(seq) - 2, 3):
        codon = seq[i:i+3].upper()
        aa1 = CODON_TABLE.get(codon, "X")
        if aa1 == "*":
            break
        aa.append(aa1)
    return "".join(aa)


def load_de_dataset(path: str) -> pd.DataFrame:
    p = Path(path)
    if not p.exists():
        raise FileNotFoundError(f"Not found: {path}")

    if p.suffix.lower() == ".tsv":
        df = pd.read_csv(p, sep="\t")
    elif p.suffix.lower() == ".json":
        with open(p, "r") as f:
            data = json.load(f)
        df = pd.DataFrame(data)
    else:
        raise ValueError("Please provide a .tsv or .json dataset file.")

    # Basic cleanup / types
    df["Directed_Evolution_Generation"] = pd.to_numeric(df["Directed_Evolution_Generation"], errors="coerce").astype("Int64")
    df["Plasmid_Variant_Index"] = pd.to_numeric(df["Plasmid_Variant_Index"], errors="coerce").astype("Int64")
    df["Parent_Plasmid_Variant"] = pd.to_numeric(df["Parent_Plasmid_Variant"], errors="coerce").astype("Int64")
    df["DNA_Quantification_fg"] = pd.to_numeric(df["DNA_Quantification_fg"], errors="coerce")
    df["Protein_Quantification_pg"] = pd.to_numeric(df["Protein_Quantification_pg"], errors="coerce")

    # Ensure Control exists
    if "Control" not in df.columns:
        df["Control"] = False

    # Drop rows missing essential fields (QC-lite)
    essential = ["Plasmid_Variant_Index", "Directed_Evolution_Generation", "Assembled_DNA_Sequence",
                 "DNA_Quantification_fg", "Protein_Quantification_pg"]
    df = df.dropna(subset=essential).copy()

    # Normalise sequences (uppercase, remove whitespace)
    df["Assembled_DNA_Sequence"] = df["Assembled_DNA_Sequence"].astype(str).str.replace(r"\s+", "", regex=True).str.upper()

    return df


