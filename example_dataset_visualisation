def compute_activity_score(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()

    # Avoid divide by zero
    out["raw_eff"] = out["DNA_Quantification_fg"] / out["Protein_Quantification_pg"].replace(0, np.nan)

    # WT baseline per generation (median for robustness)
    wt = out[out["Control"] == True].copy()
    if wt.empty:
        raise ValueError("No Control==True rows found. Need WT controls to normalise per generation.")

    wt_baseline = (
        wt.groupby("Directed_Evolution_Generation")["raw_eff"]
        .median()
        .rename("wt_raw_eff_median")
        .to_frame()
    )

    out = out.merge(wt_baseline, left_on="Directed_Evolution_Generation", right_index=True, how="left")

    # If a generation has no control rows, fall back to generation 0 if present, else overall control median
    fallback0 = wt_baseline["wt_raw_eff_median"].get(0, float(wt["raw_eff"].median()))
    out["wt_raw_eff_median"] = out["wt_raw_eff_median"].fillna(fallback0)

    out["Activity_Score"] = out["raw_eff"] / out["wt_raw_eff_median"]

    return out

