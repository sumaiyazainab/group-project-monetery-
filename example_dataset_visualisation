def extract_circular_region(seq: str, start: int, end: int) -> str:
    """Extract from a doubled-coordinate [start:end) where start< len(seq) and end can exceed len(seq)."""
    n = len(seq)
    if end <= n:
        return seq[start:end]
    else:
        return seq[start:] + seq[:(end - n)]

def get_wt_cds_and_protein(wt_seq: str, orf: Dict) -> Tuple[str, str]:
    n = len(wt_seq)
    if orf["strand"] == "+":
        cds = extract_circular_region(wt_seq, orf["start"], orf["end"])
    else:
        # ORF coords were found on revcomp(seq2), need map back:
        # For simplicity: build full revcomp of original circular sequence, then extract there.
        rc = revcomp(wt_seq)
        cds_rc = extract_circular_region(rc, orf["start"], orf["end"])
        cds = revcomp(cds_rc)  # convert back to coding orientation (5'->3' on + sense)
    aa = translate_dna(cds)
    return cds, aa

