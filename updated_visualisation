from typing import List
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import plotly.graph_objects as go
from sklearn.decomposition import PCA
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.neighbors import KNeighborsRegressor



#TOP 10 PERFORMERS TABLE


ESSENTIAL_FIELDS = [
    "Plasmid_Variant_Index",
    "Parent_Plasmid_Variant",
    "Directed_Evolution_Generation",
    "DNA_Quantification_fg",
    "Protein_Quantification_pg",
]

def top_performers_table(df: pd.DataFrame, n: int = 10) -> pd.DataFrame:
    """
    Returns top n performing non-control variants ranked by Activity_Score.
    Assumes Activity_Score and mutation columns already exist.
    """

    required_cols = ESSENTIAL_FIELDS + [
        "Activity_Score",
        "NT_Mutations_vs_WT_in_Gene",
        "AA_Mutations_vs_WT",
        "Control"
    ]

    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing required columns: {missing}")

    candidates = df[df["Control"] == False].copy()
    candidates = candidates.sort_values("Activity_Score", ascending=False)

    cols = ESSENTIAL_FIELDS + [
        "Activity_Score",
        "NT_Mutations_vs_WT_in_Gene",
        "AA_Mutations_vs_WT"
    ]

    top = candidates[cols].head(n).reset_index(drop=True)
    top["Activity_Score"] = top["Activity_Score"].astype(float).round(4)

    return top



#ACTIVITY DISTRIBUTION PER GENERATION (VIOLIN PLOT)


def plot_activity_distribution(df: pd.DataFrame):
    """
    Returns a matplotlib Figure object showing Activity Score
    distribution per generation.
    """

    required_cols = [
        "Directed_Evolution_Generation",
        "Activity_Score",
        "Control"
    ]

    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing required columns: {missing}")

    plot_df = df[df["Control"] == False].copy()

    generations = sorted(
        plot_df["Directed_Evolution_Generation"]
        .dropna()
        .unique()
        .tolist()
    )

    data = [
        plot_df.loc[
            plot_df["Directed_Evolution_Generation"] == g,
            "Activity_Score"
        ].dropna().values
        for g in generations
    ]

    fig, ax = plt.subplots(figsize=(10, 5))

    ax.violinplot(data, showmeans=True, showmedians=True)

    ax.set_xticks(np.arange(1, len(generations) + 1))
    ax.set_xticklabels([str(g) for g in generations])

    ax.set_xlabel("Generation")
    ax.set_ylabel("WT-normalised Activity Score")
    ax.set_title("Activity Score Distribution by Generation")
    ax.grid(True, alpha=0.3)

    return fig



#3D ACTIVITY LANDSCAPE


def plot_3d_activity_landscape(
    df: pd.DataFrame,
    kmer_size: int = 3,
    grid_size: int = 70,
    knn_neighbors: int = 15
):
    """
    Returns a Plotly Figure object representing
    the 3D sequence-activity landscape.
    
    Assumes:
    - Protein_Seq column exists
    - Activity_Score column exists
    - Control column exists
    """

    required_cols = ["Protein_Seq", "Activity_Score", "Control"]

    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing required columns: {missing}")

    d = df[(df["Control"] == False) & df["Protein_Seq"].notna()].copy()
    d = d.dropna(subset=["Activity_Score"])

    if len(d) < 10:
        raise ValueError("At least 10 variants required to build landscape.")

    #k-mer encoding 
    vectorizer = CountVectorizer(
        analyzer="char",
        ngram_range=(kmer_size, kmer_size)
    )
    X = vectorizer.fit_transform(d["Protein_Seq"])

    #PCA reduction 
    pca = PCA(n_components=2, random_state=42)
    coords = pca.fit_transform(X.toarray())

    d["Dim1"] = coords[:, 0]
    d["Dim2"] = coords[:, 1]

    #Grid creation
    x_lin = np.linspace(d["Dim1"].min(), d["Dim1"].max(), grid_size)
    y_lin = np.linspace(d["Dim2"].min(), d["Dim2"].max(), grid_size)
    xx, yy = np.meshgrid(x_lin, y_lin)
    grid_xy = np.c_[xx.ravel(), yy.ravel()]

    #KNN regression 
    knn = KNeighborsRegressor(
        n_neighbors=knn_neighbors,
        weights="distance"
    )
    knn.fit(d[["Dim1", "Dim2"]].values, d["Activity_Score"].values)
    zz = knn.predict(grid_xy).reshape(grid_size, grid_size)

    #Plotly figure
    fig = go.Figure()

    fig.add_trace(go.Surface(
        x=xx,
        y=yy,
        z=zz,
        surfacecolor=zz,
        colorscale="Plasma",
        opacity=0.95,
        colorbar=dict(title="Activity Score")
    ))

    fig.add_trace(go.Scatter3d(
        x=d["Dim1"],
        y=d["Dim2"],
        z=d["Activity_Score"],
        mode="markers",
        marker=dict(size=3, opacity=0.7),
        name="Variants"
    ))

    fig.update_layout(
        title="3D Activity Landscape",
        scene=dict(
            xaxis_title="Sequence Diversity (PCA 1)",
            yaxis_title="Sequence Diversity (PCA 2)",
            zaxis_title="Activity Score"
        ),
        width=900,
        height=650,
        margin=dict(l=0, r=0, b=0, t=50)
    )

    return fig
