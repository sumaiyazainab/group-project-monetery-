# ----------------------------
# UniProt
# ----------------------------
def fetch_uniprot_information(accession_id: str) -> dict:
    try:
        r = requests.get(f"https://rest.uniprot.org/uniprotkb/{accession_id}.json", timeout=10)
        if r.status_code == 200:
            return r.json()
        if r.status_code == 404:
            raise ValueError(f"UniProt accession '{accession_id}' not found (404).")
        if r.status_code == 400:
            raise ValueError("Invalid UniProt ID format (400).")
        if 500 <= r.status_code < 600:
            raise RuntimeError("UniProt server error (5xx). Try later.")
        raise RuntimeError(f"Unexpected UniProt response: {r.status_code}")
    except requests.exceptions.Timeout:
        raise RuntimeError("UniProt request timed out.")
    except requests.exceptions.RequestException as e:
        raise RuntimeError(f"Network error contacting UniProt: {e}")

def extract_uniprot_aa_sequence(uniprot_record: dict) -> str:
    try:
        return uniprot_record["sequence"]["value"]
    except (KeyError, TypeError):
        raise RuntimeError("UniProt record missing sequence.")

# ----------------------------
# FASTA parsing (WT plasmid file)
# ----------------------------
def validate_dna_sequence(sequence: str) -> None:
    nucleotides = {"A","T","C","G","N"}
    inv = sorted({c for c in sequence if c not in nucleotides})
    if inv:
        raise ValueError(f"Invalid DNA chars: {inv} (allowed A,C,G,T,N).")

def fasta_parsing(fasta_file) -> dict:
    records = list(SeqIO.parse(fasta_file, "fasta"))
    if len(records) > 1:
        raise ValueError("More than one record in FASTA; expected single plasmid.")
    if len(records) == 0:
        raise ValueError("No records found in FASTA.")
    rec = records[0]
    seq = str(rec.seq).upper()
    validate_dna_sequence(seq)
    return {"header": rec.id, "sequence": seq, "length_bp": len(seq)}

# ----------------------------
# Translation + ORF finding (circular, 6 frames)
# ----------------------------
def translate(sequence: str, start_codons: set[str] | None = None) -> str:
    codon_table = {
        'ATA':'I','ATC':'I','ATT':'I','ATG':'M',
        'ACA':'T','ACC':'T','ACG':'T','ACT':'T',
        'AAC':'N','AAT':'N','AAA':'K','AAG':'K',
        'AGC':'S','AGT':'S','AGA':'R','AGG':'R',
        'CTA':'L','CTC':'L','CTG':'L','CTT':'L',
        'CCA':'P','CCC':'P','CCG':'P','CCT':'P',
        'CAC':'H','CAT':'H','CAA':'Q','CAG':'Q',
        'CGA':'R','CGC':'R','CGG':'R','CGT':'R',
        'GTA':'V','GTC':'V','GTG':'V','GTT':'V',
        'GCA':'A','GCC':'A','GCG':'A','GCT':'A',
        'GAC':'D','GAT':'D','GAA':'E','GAG':'E',
        'GGA':'G','GGC':'G','GGG':'G','GGT':'G',
        'TCA':'S','TCC':'S','TCG':'S','TCT':'S',
        'TTC':'F','TTT':'F','TTA':'L','TTG':'L',
        'TAC':'Y','TAT':'Y','TAA':'*','TAG':'*',
        'TGC':'C','TGT':'C','TGA':'*','TGG':'W',
    }
    if start_codons is None:
        start_codons = {"ATG","GTG","TTG"}

    aa = ""
    for i in range(0, len(sequence), 3):
        codon = sequence[i:i+3]
        if len(codon) < 3:
            break
        if i == 0 and codon in start_codons:
            aa += "M"
        else:
            aa += codon_table.get(codon, "X")
    return aa

def candidate_orf(plasmid_dict: dict, start_codons: set[str] | None = None) -> list[dict]:
    seq = plasmid_dict["sequence"]
    seq = seq.upper()
    validate_dna_sequence(seq)

    circular_seq = seq + seq
    L = len(seq)

    if start_codons is None:
        start_codons = {"ATG","GTG","TTG"}
    stop_codons = {"TAA","TAG","TGA"}
    min_aa_len = 50

    orfs = []

    # forward
    for i in range(3):
        frame_seq = circular_seq[i:]
        for x in range(0, len(frame_seq)-2, 3):
            if frame_seq[x:x+3] in start_codons:
                orf_nt = ""
                for y in range(x, len(frame_seq)-2, 3):
                    cod = frame_seq[y:y+3]
                    orf_nt += cod
                    if cod in stop_codons:
                        start_coord = i + x
                        stop_coord = i + y + 3
                        length_nt = len(orf_nt)
                        if start_coord < L and length_nt <= L:
                            wraps_origin = stop_coord > L
                            orf_aa = translate(orf_nt, start_codons=start_codons).rstrip("*")
                            if len(orf_aa) >= min_aa_len:
                                orfs.append({
                                    "strand": "+",
                                    "frame": f"f{i+1}",
                                    "start_nt": start_coord,
                                    "end_nt": stop_coord,
                                    "wraps_origin": wraps_origin,
                                    "length_nt": length_nt,
                                    "orf_nt": orf_nt,
                                    "length_aa": len(orf_aa),
                                    "orf_aa": orf_aa
                                })
                        break

    # reverse complement of circular
    comp = {'A':'T','T':'A','G':'C','C':'G','N':'N'}
    rc = "".join(comp[b] for b in reversed(circular_seq))

    for i in range(3):
        frame_seq = rc[i:]
        for x in range(0, len(frame_seq)-2, 3):
            if frame_seq[x:x+3] in start_codons:
                orf_nt = ""
                for y in range(x, len(frame_seq)-2, 3):
                    cod = frame_seq[y:y+3]
                    orf_nt += cod
                    if cod in stop_codons:
                        start_rev = i + x
                        stop_rev = i + y + 3
                        length_nt = len(orf_nt)
                        if start_rev < L and length_nt <= L:
                            start_pos = start_rev % L
                            stop_pos = stop_rev % L
                            start_coord = (L - stop_pos) % L
                            stop_coord  = (L - start_pos) % L
                            wraps_origin = stop_coord <= start_coord
                            orf_aa = translate(orf_nt, start_codons=start_codons).rstrip("*")
                            if len(orf_aa) >= min_aa_len:
                                orfs.append({
                                    "strand": "-",
                                    "frame": f"r{i+1}",
                                    "start_nt": start_coord,
                                    "end_nt": stop_coord,
                                    "wraps_origin": wraps_origin,
                                    "length_nt": length_nt,
                                    "orf_nt": orf_nt,
                                    "length_aa": len(orf_aa),
                                    "orf_aa": orf_aa
                                })
                        break

    return orfs

# ----------------------------
# Alignment-based ORF selection
# ----------------------------
def length_compatibility(orf_aa_len: int, uniprot_len: int) -> bool:
    if uniprot_len <= 0:
        return False
    return int(0.8*uniprot_len) <= orf_aa_len <= int(1.2*uniprot_len)

def filter_orf_length(orfs: list[dict], uniprot_protein_seq: str) -> list[dict]:
    ul = len(uniprot_protein_seq)
    out = []
    for o in orfs:
        laa = o.get("length_aa")
        if laa is None:
            continue
        if length_compatibility(laa, ul):
            out.append(o)
    return out

def make_protein_aligner_blosum62() -> Align.PairwiseAligner:
    aligner = Align.PairwiseAligner()
    aligner.mode = "global"
    aligner.substitution_matrix = substitution_matrices.load("BLOSUM62")
    aligner.open_gap_score = -10
    aligner.extend_gap_score = -0.5
    return aligner

def seq_alignment_score(aligner, uniprot_aa: str, orf_aa: str) -> float:
    return aligner.score(uniprot_aa, orf_aa)

def select_best_orf_by_alignment(orfs: list[dict], uniprot_protein_seq: str, score_fraction_threshold=0.85) -> dict:
    if not uniprot_protein_seq or not isinstance(uniprot_protein_seq, str):
        return {"status":"no_match_found","message":"UniProt protein sequence missing/invalid."}
    if not orfs:
        return {"status":"no_orfs_found","message":"No ORFs found."}

    filtered = filter_orf_length(orfs, uniprot_protein_seq)
    if not filtered:
        filtered = orfs

    aligner = make_protein_aligner_blosum62()
    best_orf = None
    best_score = float("-inf")

    for o in filtered:
        aa = o.get("orf_aa")
        if not aa:
            continue
        sc = seq_alignment_score(aligner, uniprot_protein_seq, aa)
        if sc > best_score:
            best_score = sc
            best_orf = o

    if best_orf is None:
        return {"status":"no_match_found","message":"ORFs found but none alignable."}

    max_score = seq_alignment_score(aligner, uniprot_protein_seq, uniprot_protein_seq)
    if max_score <= 0:
        return {"status":"no_match_found","message":"Invalid UniProt self-alignment score."}

    frac = best_score / max_score
    res = best_orf.copy()
    res.update({
        "alignment_score": best_score,
        "score_fraction": frac,
        "filtered_orf_count": len(filtered),
        "total_orf_count": len(orfs),
    })

    if frac >= score_fraction_threshold:
        res["status"] = "match_found"
    else:
        res["status"] = "no_match_found"
        res["message"] = "Best ORF does not meet similarity threshold."

    return res
import numpy as np
