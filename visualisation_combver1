ESSENTIAL_FIELDS = [
    "Plasmid_Variant_Index",
    "Parent_Plasmid_Variant",
    "Directed_Evolution_Generation",
    "Assembled_DNA_Sequence",
    "DNA_Quantification_fg",
    "Protein_Quantification_pg",
]

def load_tsv_or_json(path: str) -> pd.DataFrame:
    if path.endswith(".tsv"):
        return pd.read_csv(path, sep="\t")
    if path.endswith(".json"):
        return pd.read_json(path)
    raise ValueError("Unsupported file format (need .tsv or .json)")

def qc_drop_incomplete_rows(df: pd.DataFrame):
    missing = [c for c in ESSENTIAL_FIELDS if c not in df.columns]
    if missing:
        raise ValueError(f"Missing essential columns: {missing}")
    clean = df.dropna(subset=ESSENTIAL_FIELDS).copy()
    rejected = df.loc[~df.index.isin(clean.index)].copy()
    return clean, rejected

def codonize(nt: str):
    nt = str(nt).upper().replace(" ", "").replace("\n","").replace("\r","")
    L = (len(nt)//3)*3
    nt = nt[:L]
    return [nt[i:i+3] for i in range(0, len(nt), 3)]

def classify_codon_mutations(wt_orf_nt: str, var_orf_nt: str):
    wt_cod = codonize(wt_orf_nt)
    va_cod = codonize(var_orf_nt)
    n = min(len(wt_cod), len(va_cod))

    muts = []
    syn = 0
    nonsyn = 0

    for i in range(n):
        wc = wt_cod[i]
        vc = va_cod[i]
        if wc == vc:
            continue

        wt_aa = translate(wc).replace("*","")
        va_aa = translate(vc).replace("*","")
        aa_pos = i + 1

        if wt_aa == va_aa:
            syn += 1
            mtype = "synonymous"
        else:
            nonsyn += 1
            mtype = "nonsynonymous"

        muts.append({
            "aa_position": aa_pos,
            "wt_codon": wc,
            "var_codon": vc,
            "wt_aa": wt_aa,
            "var_aa": va_aa,
            "mutation_type": mtype,
        })

    if len(wt_cod) != len(va_cod):
        muts.append({
            "aa_position": None,
            "wt_codon": None,
            "var_codon": None,
            "wt_aa": None,
            "var_aa": None,
            "mutation_type": "length_mismatch_indel_or_truncation",
            "note": f"WT_codons={len(wt_cod)} VAR_codons={len(va_cod)}",
        })

    return muts, syn, nonsyn

def compute_activity_score(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()
    out["DNA_over_Protein"] = out["DNA_Quantification_fg"] / out["Protein_Quantification_pg"]

    # define controls:
    if "Control" in out.columns:
        ctrl = out["Control"] == True
    else:
        # common fallback: WT control rows indexed as 0
        ctrl = out["Plasmid_Variant_Index"] == 0

    per_gen_ctrl = (
        out.loc[ctrl]
          .groupby("Directed_Evolution_Generation")["DNA_over_Protein"]
          .mean()
          .rename("Control_Ratio_Gen")
    )
    global_ctrl = out.loc[ctrl, "DNA_over_Protein"].mean()

    out = out.merge(per_gen_ctrl, how="left",
                    left_on="Directed_Evolution_Generation", right_index=True)

    out["Control_Ratio_Gen"] = out["Control_Ratio_Gen"].fillna(global_ctrl)
    out["Activity_Score"] = out["DNA_over_Protein"] / out["Control_Ratio_Gen"]
    return out

def run_analysis(clean_df: pd.DataFrame, uniprot_aa: str, score_fraction_threshold=0.85):
    df = clean_df.copy()

    # pick a WT row to define WT ORF (prefer Control==True)
    if "Control" in df.columns and (df["Control"] == True).any():
        wt_row = df.loc[df["Control"] == True].sort_values("Directed_Evolution_Generation").iloc[0]
    else:
        wt_row = df.sort_values(["Directed_Evolution_Generation","Plasmid_Variant_Index"]).iloc[0]

    wt_seq = wt_row["Assembled_DNA_Sequence"]
    wt_orfs = candidate_orf({"sequence": wt_seq, "header":"wt", "length_bp":len(wt_seq)})
    wt_best = select_best_orf_by_alignment(wt_orfs, uniprot_aa, score_fraction_threshold=score_fraction_threshold)
    if wt_best.get("status") != "match_found":
        raise ValueError(f"WT gene not confidently found. {wt_best.get('message','')}")

    wt_orf_nt = wt_best["orf_nt"]

    # columns to add
    df["Protein_Sequence"] = None
    df["Synonymous_Mutations"] = np.nan
    df["Nonsynonymous_Mutations"] = np.nan
    df["Total_Mutations"] = np.nan
    df["Gene_Score_Fraction"] = np.nan

    mutation_rows = []

    for i, row in df.iterrows():
        seq = row["Assembled_DNA_Sequence"]
        orfs = candidate_orf({"sequence": seq, "header":"var", "length_bp":len(seq)})
        best = select_best_orf_by_alignment(orfs, uniprot_aa, score_fraction_threshold=score_fraction_threshold)

        if best.get("status") != "match_found":
            # keep row but mark as failed gene-call
            continue

        df.at[i, "Protein_Sequence"] = best["orf_aa"]
        df.at[i, "Gene_Score_Fraction"] = best["score_fraction"]

        muts, syn, nonsyn = classify_codon_mutations(wt_orf_nt, best["orf_nt"])
        df.at[i, "Synonymous_Mutations"] = syn
        df.at[i, "Nonsynonymous_Mutations"] = nonsyn
        df.at[i, "Total_Mutations"] = syn + nonsyn

        for m in muts:
            mutation_rows.append({
                "Plasmid_Variant_Index": row["Plasmid_Variant_Index"],
                "Directed_Evolution_Generation": row["Directed_Evolution_Generation"],
                "Parent_Plasmid_Variant": row["Parent_Plasmid_Variant"],
                **m
            })

    mutations_df = pd.DataFrame(mutation_rows)

    # activity score
    df = compute_activity_score(df)

    # Top 10
    top10 = (
        df.dropna(subset=["Activity_Score"])
          .sort_values("Activity_Score", ascending=False)
          .head(10)
          .loc[:, ESSENTIAL_FIELDS + ["Activity_Score","Total_Mutations"]]
          .reset_index(drop=True)
    )

    return df, mutations_df, top10

