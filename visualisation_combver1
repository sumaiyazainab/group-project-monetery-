def plot_activity_violin_like_example(enriched_df, score_col="Activity_Score", gen_col="Directed_Evolution_Generation",
                                      save_path=None):
    # drop missing scores
    df = enriched_df.dropna(subset=[score_col]).copy()

    # ensure generations sorted
    gens = sorted(df[gen_col].unique())
    data = [df.loc[df[gen_col] == g, score_col].values for g in gens]

    fig, ax = plt.subplots(figsize=(9, 6))

    # 1) Violin shapes
    vp = ax.violinplot(
        data,
        positions=np.arange(1, len(gens) + 1),
        widths=0.75,
        showmeans=False,
        showmedians=False,
        showextrema=False
    )

    # make violin semi-transparent like the example
    for body in vp["bodies"]:
        body.set_alpha(0.35)

    # 2) Boxplot overlay (gives whiskers + median)
    ax.boxplot(
        data,
        positions=np.arange(1, len(gens) + 1),
        widths=0.18,
        patch_artist=True,
        showfliers=False
    )

    # 3) Add mean marker (like the little bar/cross in the example)
    means = [np.mean(d) if len(d) else np.nan for d in data]
    ax.plot(np.arange(1, len(gens) + 1), means, marker="_", linestyle="None", markersize=18)

    # Labels + title to match example
    ax.set_title("Activity Score Distribution by Generation")
    ax.set_xlabel("Generation")
    ax.set_ylabel("Activity Score")

    ax.set_xticks(np.arange(1, len(gens) + 1))
    ax.set_xticklabels([str(g) for g in gens])

    ax.grid(True, axis="y", alpha=0.3)
    plt.tight_layout()

    if save_path:
        plt.savefig(save_path, dpi=300)
        print("Saved:", save_path)

    plt.show()
